ADMIN_USER=admin
ADMIN_PASSWORD=changeme
JWT_SECRET=troque-por-uma-string-secreta-longa
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/rastreamentowpp
FRONTEND_URL=http://localhost:5173

# Meta Business Manager
# APP_SECRET: developers.facebook.com → App → Configurações → Básico → "Segredo do Aplicativo"
APP_SECRET=seu-app-secret-do-meta

# Meta Graph API / CAPI
# Estas variáveis funcionam como fallback caso não sejam configuradas pelo painel (/settings)
META_ACCESS_TOKEN=EAAxxxx...
META_PIXEL_ID=123456789012345
META_PAGE_ID=123456789
# act_xxx: ID da conta de anúncios (format: act_123456789)
# Usado para validar que o anúncio pertence à conta correta ao buscar dados na Graph API
META_AD_ACCOUNT_ID=act_123456789
